{
  "name": "agent-harness",
  "private": true,
  "workspaces": [
    "agents/*",
    "mcps/*",
    "runtimes/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "check": "vp check",
    "fmt": "vp fmt .",
    "fmt:check": "vp fmt --check .",
    "lint": "vp lint .",
    "test": "vp test",
    "typecheck": "tsgo -p tsconfig.json",
    "agent:new": "bun run scripts/create-agent.ts",
    "memoli:release:check": "goreleaser check --config .goreleaser.yaml",
    "memoli:release:snapshot": "goreleaser release --snapshot --clean --config .goreleaser.yaml",
    "memoli:release": "goreleaser release --clean --config .goreleaser.yaml",
    "mcp:agent-catalog": "bun run --cwd mcps/agent-catalog stdio",
    "mcp:memoli": "bun run --cwd mcps/memoli stdio",
    "memoli": "bun run --cwd packages/memoli cli",
    "runtime:local": "bun run --cwd runtimes/node dev",
    "runtime:cf": "bun run --cwd runtimes/cloudflare dev",
    "runtime:cf:deploy": "bun run --cwd runtimes/cloudflare build && bun run --cwd runtimes/cloudflare deploy",
    "runtime:vercel": "bun run --cwd runtimes/vercel dev",
    "runtime:vercel:deploy": "bun run --cwd runtimes/vercel build && bun run --cwd runtimes/vercel deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260619.1",
    "@flue/cli": "1.0.0-beta.5",
    "@types/bun": "1.3.14",
    "@types/node": "26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260619.1",
    "typescript": "7.0.1-rc",
    "vite": "8.1.0",
    "vite-plus": "0.2.1",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "packageManager": "bun@1.3.13"
}
