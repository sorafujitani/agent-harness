{
  "name": "@agent-harness/memoli",
  "version": "2.0.1",
  "private": true,
  "description": "CLI markdown memo manager and MCP server",
  "bin": {
    "memoli": "./bin/memoli"
  },
  "type": "module",
  "exports": {
    ".": "./src/cli.ts",
    "./mcp/server": "./src/mcp/server.ts"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "serve": "bun run src/cli.ts serve",
    "build": "tsgo -p tsconfig.json",
    "check": "tsgo -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "vitest": "4.1.9"
  }
}
