{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortPackageJson": true,
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    ".cache/**",
    ".direnv/**",
    ".flue-vite/**",
    ".wrangler/**"
  ]
}
